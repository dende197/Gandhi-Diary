# Groq AI (used for AI chat and circolari summaries)
GROQ_API_KEY=gsk_...

# Supabase Configuration
SUPABASE_URL=https://...
SUPABASE_SERVICE_ROLE_KEY=ey...

# App Config
DEBUG_MODE=false

# Google Calendar OAuth2 (per-user flow)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/api/google?action=callback

# Vercel Cron Protection (required — set the same value in Vercel environment variables)
CRON_SECRET=your_random_secret_here

# Argo Password Encryption Key — 64 hex characters (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be set to encrypt Argo passwords at rest. Without it passwords are stored in cleartext.
ARGO_ENCRYPTION_KEY=your_64_hex_char_key_here

# School Circolari URL (optional, falls back to default)
SCHOOL_CIRCOLARI_URL=https://www.liceogandhi.edu.it/categoria/storico-circolari/
