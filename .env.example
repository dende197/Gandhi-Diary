# Argo Credentials (for automatic cron sync)
ARGO_SCHOOL_CODE=YOUR_SCHOOL_CODE
ARGO_USERNAME=your_argo_username
ARGO_PASSWORD=your_argo_password

# Vercel Cron Protection
CRON_SECRET=your_random_secret_here
