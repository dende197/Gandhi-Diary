# Gemini API Keys
GEMINI_API_KEY_PLANNER=AIzaSy...
GEMINI_API_KEY_SINTESI=AIzaSy...

# Supabase Configuration
SUPABASE_URL=https://...
SUPABASE_SERVICE_ROLE_KEY=ey...

# App Config
DEBUG_MODE=false
PORT=3000

# Google Calendar Integration
# Ottieni le credenziali OAuth2 da https://console.cloud.google.com/
# Abilita l'API Google Calendar e crea credenziali OAuth2 (tipo: Web application)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# URI di redirect (deve corrispondere a quello configurato nella Console Google)
GOOGLE_REDIRECT_URI=https://your-backend.onrender.com/api/calendar/callback

# Chiave AES-256 per cifrare le credenziali Argo salvate per la sincronizzazione automatica
# Deve essere lunga esattamente 32 caratteri
CALENDAR_ENCRYPTION_KEY=change-this-to-32-char-secret-key
