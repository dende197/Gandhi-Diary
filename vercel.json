{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/login",
      "destination": "/api/auth?action=login"
    },
    {
      "source": "/sync",
      "destination": "/api/auth?action=sync"
    },
    {
      "source": "/health",
      "destination": "/api/main?action=health"
    },
    {
      "source": "/api/ping",
      "destination": "/api/main?action=ping"
    },
    {
      "source": "/api/resolve-profile",
      "destination": "/api/auth?action=resolve-profile"
    },
    {
      "source": "/api/profile/:user_id",
      "destination": "/api/profile?user_id=:user_id"
    },
    {
      "source": "/api/profile",
      "destination": "/api/profile"
    },
    {
      "source": "/api/planner/:user_id",
      "destination": "/api/planner?user_id=:user_id"
    },
    {
      "source": "/api/circolari",
      "destination": "/api/circolari?action=index"
    },
    {
      "source": "/api/circolari/sintesi",
      "destination": "/api/circolari?action=sintesi"
    },
    {
      "source": "/api/ai/chat",
      "destination": "/api/ai?action=chat"
    },
    {
      "source": "/api/mental-health/ai-advice",
      "destination": "/api/ai?action=ai-advice"
    },
    {
      "source": "/api/mental-health/save",
      "destination": "/api/mental?action=save"
    },
    {
      "source": "/api/mental-health/history",
      "destination": "/api/mental?action=history"
    },
    {
      "source": "/api/conversations/user/:user_id",
      "destination": "/api/conversations?user_id=:user_id"
    },
    {
      "source": "/api/debug/profile-raw",
      "destination": "/api/debug"
    },
    {
      "source": "/api/calendar/auth",
      "destination": "/api/calendar?action=auth"
    },
    {
      "source": "/api/calendar/callback",
      "destination": "/api/calendar?action=callback"
    },
    {
      "source": "/api/calendar/status",
      "destination": "/api/calendar?action=status"
    },
    {
      "source": "/api/calendar/sync",
      "destination": "/api/calendar?action=sync"
    },
    {
      "source": "/api/calendar/register-sync",
      "destination": "/api/calendar?action=register-sync"
    },
    {
      "source": "/api/calendar/disconnect",
      "destination": "/api/calendar?action=disconnect"
    },
    {
      "source": "/api/calendar/events",
      "destination": "/api/calendar?action=events"
    },
    {
      "source": "/.well-known/assetlinks.json",
      "destination": "/.well-known/assetlinks.json"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,PUT,DELETE,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, X-Requested-With, X-Client-Info, apikey, x-id-soggetto, x-prg-soggetto, x-auth-token"
        }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}