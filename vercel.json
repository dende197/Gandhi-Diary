{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron-sync",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron-sync",
      "schedule": "0 23 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/main?action=health"
    },
    {
      "source": "/login",
      "destination": "/api/auth?action=login"
    },
    {
      "source": "/sync",
      "destination": "/api/auth?action=sync"
    },
    {
      "source": "/api/planner/:user_id",
      "destination": "/api/resources"
    },
    {
      "source": "/api/profile/:user_id",
      "destination": "/api/resources"
    },
    {
      "source": "/api/ai/:action",
      "destination": "/api/ai"
    },
    {
      "source": "/api/ping",
      "destination": "/api/main?action=ping"
    },
    {
      "source": "/api/debug/:action",
      "destination": "/api/main?action=:action"
    },
    {
      "source": "/api/circolari/:action",
      "destination": "/api/circolari?action=:action"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,PUT,DELETE,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, X-Requested-With, X-Client-Info, apikey, x-id-soggetto, x-prg-soggetto, x-auth-token"
        }
      ]
    }
  ]
}